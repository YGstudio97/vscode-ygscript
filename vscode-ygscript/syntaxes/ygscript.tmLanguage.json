{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "YGScript",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ygscript",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ygscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ygscript",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.interpolated.ygscript",
          "begin": "I\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ygscript",
              "match": "\\\\."
            },
            {
              "name": "variable.other.interpolated.ygscript",
              "match": "\\{[^}]+\\}"
            }
          ]
        },
        {
          "name": "string.quoted.single.ygscript",
          "match": "'[^']*'"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ygscript",
          "match": "\\b(if|eif|else|incase|case|default|when|though|for|while|do|agin|break|continue|return)\\b"
        },
        {
          "name": "storage.type.ygscript",
          "match": "\\b(let|var|const|fnc)\\b"
        },
        {
          "name": "keyword.other.module.ygscript",
          "match": "\\b(add|from|as|-as|-add)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.ygscript",
          "match": "\\b(int|uint|char|bool|float|double|string|str|obj|object|null|class)\\b"
        },
        {
          "name": "entity.name.type.numeric.ygscript",
          "match": "\\b(int8|int16|int32|int64|int128|int256|int512|uint8|uint16|uint32|uint64|uint128|uint256|uint512|float8|float16|float32|float64|float80|float128|float256|float512|double8|double16|double32|double64|double80|double128|double256|double512)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.ygscript",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.ygscript",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.ygscript",
          "match": "\\b(null)\\b"
        },
        {
          "name": "constant.numeric.ygscript",
          "match": "\\b(0[xX][0-9a-fA-F]+|0[oO][0-7]+|0[bB][01]+|[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?)([A-Za-z0-9_]*)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.ygscript",
          "match": "(\\+|-|\\*|/|%|==|!=|<|>|<=|>=|&&|\\|\\||!|&|\\||\\^|~|<<|>>|=|\\+=|-=|\\*=|/=|\\+\\+|--|->|\\?)"
        }
      ]
    }
  },
  "scopeName": "source.ygscript"
}
