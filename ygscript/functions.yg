// Functions Example
fnc Add(x: int32, y: int32) -> int32 {
    return x + y
}

fnc Multiply(a: int32, b: int32) -> int32 {
    return a * b
}

fnc Main() {
    let sum = Add(5, 10)
    show("5 + 10 = ")
    show(sum)
    
    let product = Multiply(3, 7)
    show("3 * 7 = ")
    show(product)
    
    return 0
}
